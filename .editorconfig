root = true

[*]
end_of_line = lf
insert_final_newline = true
indent_size = 2
tab_width = 4

[*.{lua,sh,bash,toml,txt,md,bat,cmd,ps1}]
indent_style = space

[*.{bat,cmd,ps1}]
end_of_line = crlf

[*.md]
trim_trailing_whitespace = false

[*.py]
indent_style = space
indent_size = 4

[{*Makefile,*makefile,*.mk}]
indent_style = tab
tab_width = 8
